# =============================================================================
# OpenClaw Workday Agent — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# =============================================================================

# --- Chrome DevTools Protocol (Browser Automation) ---
# Token for authenticating with the Chrome CDP endpoint
CHROME_CDP_TOKEN=your_cdp_token_here
# Port where Chrome DevTools Protocol is listening
CHROME_CDP_PORT=9222

# --- Organization ---
# Your organization's full legal name
ORG_NAME=Your Company GmbH
# SSO identity provider name shown on the Workday login screen
SSO_PROVIDER_NAME=YourCompany
# Azure AD / Entra tenant ID (extracted from the direct login link)
ORG_TENANT_ID=00000000-0000-0000-0000-000000000000
# Direct SSO login link (fallback if clicking the provider button fails)
ORG_TENANT_DIRECT_LINK=https://myapps.microsoft.com/signin/workday-sso/<app-id>?tenantId=<tenant-id>

# --- Workday Configuration ---
# Your Workday tenant base URL (without trailing slash)
WORKDAY_BASE_URL=https://wd3.myworkday.com/your_tenant
# Relative path to time tracking page
WORKDAY_TIME_TRACKING_PATH=/d/inst/247$15285/rel-task/2998$10955.htmld
# Relative path to tasks/inbox page
WORKDAY_TASKS_PATH=/d/task/2998$44084.htmld
# Workday home page (for inbox navigation)
WORKDAY_HOME_PATH=/d/home.htmld

# --- Browser Automation Strategy ---
# Strategy: headless_first (try Playwright, fallback to CDP relay),
#           relay_only (existing Chrome only), headless_only (Playwright only)
BROWSER_STRATEGY=headless_first
# Run Playwright in headless mode (true) or with visible browser (false)
PLAYWRIGHT_HEADLESS=true
# Playwright navigation timeout in milliseconds
PLAYWRIGHT_TIMEOUT=30000

# --- Pipeline Runner ---
# Path to the Python pipeline runner (relative to project root)
PIPELINE_RUNNER_PATH=tools/pipeline_runner

# --- OpenClaw Configuration (optional) ---
# Path to openclaw config file (defaults to ~/.openclaw/openclaw.json)
# OPENCLAW_CONFIG_PATH=~/.openclaw/openclaw.json
